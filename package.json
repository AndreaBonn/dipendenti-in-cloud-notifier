{
  "name": "promemoria-timbrature",
  "version": "2.0.0",
  "description": "Chrome extension (unofficial) for dipendentincloud.it time-clock reminders",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint --no-warn-ignored 'src/**/*.js' 'tests/**/*.js'",
    "lint:fix": "eslint --no-warn-ignored 'src/**/*.js' 'tests/**/*.js' --fix",
    "format": "prettier --write 'src/**/*.{js,css,html}' 'tests/**/*.js' '*.{js,json,md}'",
    "format:check": "prettier --check 'src/**/*.{js,css,html}' 'tests/**/*.js' '*.{js,json,md}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "chrome-extension",
    "manifest-v3",
    "time-clock",
    "reminder",
    "dipendentincloud"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AndreaBonn/dipendenti-in-cloud-notifier.git"
  },
  "author": "Andrea Bonacci",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/AndreaBonn/dipendenti-in-cloud-notifier/issues"
  },
  "homepage": "https://github.com/AndreaBonn/dipendenti-in-cloud-notifier#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.2",
    "vitest": "^4.1.4"
  }
}
