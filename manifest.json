{
  "manifest_version": 3,
  "name": "Promemoria Timbrature",
  "version": "2.0.0",
  "description": "Estensione NON UFFICIALE per ricordare di timbrare su dipendentincloud.it. Notifiche, countdown e timbratura rapida.",
  "author": "Andrea Bonacci",
  "homepage_url": "https://github.com/AndreaBonn/dipendenti-in-cloud-notifier",
  "action": {
    "default_popup": "src/pages/popup/popup.html",
    "default_icon": {
      "16": "images/timer-green-16.png",
      "48": "images/timer-green-48.png",
      "128": "images/timer-green-128.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "default-src 'none'; script-src 'self'; object-src 'none'; connect-src 'none'; img-src 'self'; style-src 'self'; frame-src 'none'; media-src 'none'; font-src 'none'"
  },
  "minimum_chrome_version": "116",
  "permissions": ["storage", "offscreen", "notifications", "alarms"],
  "host_permissions": ["*://secure.dipendentincloud.it/*", "*://cloud.dipendentincloud.it/*"],
  "content_scripts": [
    {
      "matches": ["*://secure.dipendentincloud.it/*", "*://cloud.dipendentincloud.it/*"],
      "js": ["src/content/content.js"]
    }
  ],
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "options_page": "src/pages/options/options.html",
  "icons": {
    "16": "images/timer-green-16.png",
    "48": "images/timer-green-48.png",
    "128": "images/timer-green-128.png"
  }
}
